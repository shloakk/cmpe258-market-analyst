DEFAULT_MODEL=gemini
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional model keys when DEFAULT_MODEL uses these providers.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional Langfuse tracing. Leave blank to run without observability.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
