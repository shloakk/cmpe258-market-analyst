DEFAULT_MODEL=gemini
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=qwen/qwen3-coder:free
NEMOTRON_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Optional paid OpenAI provider for cross-comparison with the free lineup.
# Required only when DEFAULT_MODEL=gpt or when 'gpt' is included in /compare,
# /eval/run, or `python eval/evaluator.py --models gpt ...`.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Optional Langfuse tracing. Leave blank to run without observability.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
